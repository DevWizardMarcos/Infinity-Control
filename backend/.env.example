# Copie este arquivo para ".env" e ajuste os valores para a sua escola.
# O ".env" real NUNCA deve ser commitado (contém senhas).

# ---------------------------------------------------------------------------
# Escola / rede
# ---------------------------------------------------------------------------
SCHOOL_NAME=Minha Escola

# IP de broadcast usado para enviar os pacotes Wake-on-LAN.
# Use 255.255.255.255 para broadcast geral ou o broadcast da sua sub-rede
# (ex: 192.168.1.255) se o roteador bloquear broadcast geral.
WOL_BROADCAST_IP=255.255.255.255

# Porta e timeout padrão para conexões SSH.
DEFAULT_SSH_PORT=22
DEFAULT_SSH_TIMEOUT=10

# Caminho do CSV com o inventário de computadores (colunas: MAC,IP,Sala).
COMPUTERS_CSV_PATH=computadores.csv

# ---------------------------------------------------------------------------
# Salas
# ---------------------------------------------------------------------------
# Lista de salas separadas por vírgula. Cada nome deve corresponder à coluna
# "Sala" do arquivo CSV acima.
SALAS=Sala1,Sala2,Laboratorio

# Configuração padrão aplicada a salas que não tiverem variáveis específicas
# (SALA_<NOME>_*) definidas abaixo. "os" aceita "linux" ou "windows".
DEFAULT_SALA_OS=windows
DEFAULT_SALA_USERNAME=aluno
DEFAULT_SALA_PASSWORD=troque-esta-senha
DEFAULT_SALA_SSH_PORT=22

# Configuração específica por sala: SALA_<NOME_EM_MAIUSCULO>_<CAMPO>
# (troque espaços por "_" no nome da sala). Todos os campos são opcionais;
# o que não for definido usa o valor padrão (DEFAULT_SALA_*) acima.
SALA_SALA1_OS=linux
SALA_SALA1_USERNAME=admin
SALA_SALA1_PASSWORD=troque-esta-senha

SALA_SALA2_OS=windows
SALA_SALA2_USERNAME=aluno
SALA_SALA2_PASSWORD=troque-esta-senha

SALA_LABORATORIO_OS=linux
SALA_LABORATORIO_USERNAME=aluno
SALA_LABORATORIO_PASSWORD=troque-esta-senha
SALA_LABORATORIO_SSH_PORT=22

# ---------------------------------------------------------------------------
# Autenticação / API (FastAPI)
# ---------------------------------------------------------------------------
# Gere um valor aleatório, ex: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-este-valor-por-um-segredo-aleatorio
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Banco SQLite com os usuários do sistema.
DATABASE_URL=sqlite:///./users.db

# Cargo que tem permissão de usar o sistema (usuários com outro cargo fazem
# login, mas recebem 403 ao acessar os recursos).
ALLOWED_CARGO=TI

# Origens permitidas para requisições da interface web (CORS).
# Separe múltiplas origens por vírgula, ex: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=*
